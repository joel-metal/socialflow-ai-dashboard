{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "paths": {
      "@socialflow/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../packages/shared/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/modules",
    "src/shared",
    "src/tests",
    "src/__tests__/database",
    "src/__tests__/integration"
  ]
}
